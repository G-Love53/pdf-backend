<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sign bind authorization — <%= segmentBrandName %></title>
    <style>
      * {
        box-sizing: border-box;
      }
      html,
      body {
        height: 100%;
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f9fafb;
        color: #111827;
      }
      .layout {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        max-width: 1200px;
        margin: 0 auto;
      }
      .header {
        flex-shrink: 0;
        padding: 16px 20px 12px;
        background: #ffffff;
        border-bottom: 1px solid #e5e7eb;
      }
      .brand-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 10px;
      }
      .brand-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: <%= segmentColor %>;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        font-weight: 700;
      }
      .brand-text {
        font-size: 15px;
        font-weight: 700;
        color: #111827;
      }
      .brand-sub {
        font-size: 11px;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-top: 2px;
      }
      .intro {
        font-size: 15px;
        line-height: 1.5;
        color: #374151;
        margin: 0;
      }
      .ref {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 8px;
      }
      .main {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 0;
        padding: 12px 16px 16px;
      }
      .iframe-shell {
        flex: 1;
        min-height: 0;
        display: flex;
        flex-direction: column;
      }
      .iframe-shell iframe {
        flex: 1;
        width: 100%;
        min-height: 0;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #fff;
      }
    </style>
  </head>
  <body>
    <div class="layout">
      <header class="header">
        <div class="brand-row">
          <div class="brand-icon"><%= segmentIcon %></div>
          <div>
            <div class="brand-text"><%= segmentBrandName %></div>
            <div class="brand-sub">Commercial Insurance Direct</div>
          </div>
        </div>
        <p class="intro">Please review and sign your bind authorization below.</p>
        <% if (submissionPublicId) { %>
        <div class="ref">Reference: <%= submissionPublicId %></div>
        <% } %>
      </header>
      <main class="main">
        <div class="iframe-shell">
          <iframe
            id="boldsign-iframe"
            title="Electronic signature"
            src="<%= boldsignSendUrl %>"
            allow="clipboard-read; clipboard-write"
          ></iframe>
        </div>
      </main>
    </div>
  </body>
</html>
