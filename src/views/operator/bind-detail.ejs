<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>CID — Bind Detail</title>
    <style>
      body { font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif; margin: 0; padding: 0; background: #f9fafb; }
      .operator-topbar { background: #020617; color: #e5e7eb; padding: 12px 20px; border-bottom: 1px solid #1f2937; }
      .bind-body { padding: 16px; display: flex; gap: 16px; }
      .col { flex: 1; }
      h1 { font-size: 20px; margin-bottom: 8px; }
      label { display: block; margin-top: 8px; font-size: 13px; }
      input, select, textarea { width: 100%; padding: 6px 8px; margin-top: 2px; font-size: 13px; }
      button { margin-top: 12px; padding: 8px 16px; font-size: 13px; cursor: pointer; }
      pre { background: #f9fafb; padding: 8px; font-size: 11px; }
    </style>
  </head>
  <body>
    <div class="operator-topbar">
      <%- include('../partials/operator-nav', { segmentQuery: typeof segmentQuery !== 'undefined' ? segmentQuery : '', segment: typeof segment !== 'undefined' ? segment : 'all' }) %>
    </div>
    <div class="bind-body">
    <div class="col">
      <h1>Bind Detail</h1>
      <div id="summary"></div>

      <h3>Signer</h3>
      <label>
        Name
        <input id="signer-name" />
      </label>
      <label>
        Email
        <input id="signer-email" />
      </label>
      <label>
        Payment Method
        <select id="payment-method">
          <option value="annual">Annual</option>
          <option value="monthly">Monthly (estimate)</option>
        </select>
      </label>
      <label>
        Agent Notes
        <textarea id="agent-notes" rows="3"></textarea>
      </label>
      <button id="send-btn">Send for E‑Signature</button>
      <pre id="status"></pre>

      <div style="margin-top: 12px; display: none;" id="iframe-wrap">
        <iframe
          id="boldsign-iframe"
          style="width: 100%; height: 65vh; border: 1px solid #e5e7eb; border-radius: 8px;"
          src=""
        ></iframe>
      </div>

      <div style="margin-top: 12px; display: none;" id="signed-doc-wrap">
        <h3 style="font-size: 14px; margin: 0 0 8px 0;">Signed Document</h3>
        <a id="signed-doc-link" href="#" target="_blank" rel="noopener noreferrer">Open signed PDF</a>
      </div>
    </div>
    </div>

    <script>
      const quoteId = "<%= quoteId %>";

      async function loadDetails() {
        const res = await fetch(`/api/quotes/${quoteId}/bind-details`);
        if (!res.ok) {
          document.getElementById("summary").textContent = "Failed to load bind details.";
          return;
        }
        const d = await res.json();
        document.getElementById("summary").innerHTML = `
          <strong>${d.client.business_name || ""}</strong><br/>
          ${d.client.address || ""}<br/><br/>
          Carrier: ${d.quote.carrier_name || ""}<br/>
          Policy: ${d.quote.policy_type || ""}<br/>
          Premium: $${(d.quote.annual_premium || 0).toFixed(2)}<br/>
          Effective: ${d.quote.effective_date || ""}<br/>
        `;
        document.getElementById("signer-name").value = d.client.contact_name || "";
        document.getElementById("signer-email").value = d.client.email || "";

        // If already signed, show signed doc link and avoid embedding.
        const status = d.bind_request?.status || null;
        const signedUrl = d.bind_request?.signed_document_url || null;
        if (status === "signed" && signedUrl) {
          const wrap = document.getElementById("signed-doc-wrap");
          const link = document.getElementById("signed-doc-link");
          wrap.style.display = "block";
          link.href = signedUrl;
          const iframeWrap = document.getElementById("iframe-wrap");
          iframeWrap.style.display = "none";
        }
      }

      let pollTimer = null;
      async function pollBindStatus() {
        const res = await fetch(`/api/quotes/${quoteId}/bind-details`);
        if (!res.ok) return;
        const d = await res.json();
        const status = d.bind_request?.status || null;

        if (status === "signed") {
          if (pollTimer) clearInterval(pollTimer);
          pollTimer = null;
          loadDetails();
        }
      }

      document.getElementById("send-btn").addEventListener("click", async () => {
        const body = {
          agent_id: null,
          payment_method: document.getElementById("payment-method").value,
          effective_date_override: null,
          agent_notes: document.getElementById("agent-notes").value || null,
          signer_name: document.getElementById("signer-name").value,
          signer_email: document.getElementById("signer-email").value,
        };
        const res = await fetch(`/api/quotes/${quoteId}/bind/initiate`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(body),
        });
        const out = await res.json();
        document.getElementById("status").textContent = JSON.stringify(out, null, 2);

        if (out.boldsign_send_url) {
          const iframeWrap = document.getElementById("iframe-wrap");
          const iframe = document.getElementById("boldsign-iframe");
          iframeWrap.style.display = "block";
          iframe.src = out.boldsign_send_url;
        }

        if (pollTimer) clearInterval(pollTimer);
        pollTimer = setInterval(pollBindStatus, 5000);
      });

      loadDetails();
    </script>
  </body>
</html>

