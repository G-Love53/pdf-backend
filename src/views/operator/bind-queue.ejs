<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>CID — Bind Queue</title>
    <style>
      body { font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif; padding: 16px; }
      h1 { font-size: 20px; margin-bottom: 8px; }
      table { border-collapse: collapse; width: 100%; margin-top: 12px; }
      th, td { border: 1px solid #ddd; padding: 8px; font-size: 13px; }
      th { background: #f3f4f6; text-align: left; }
      a { color: #2563eb; text-decoration: none; }
      a:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <h1>Bind Queue</h1>
    <p>Quotes with packets sent and ready to bind.</p>

    <table id="bind-table">
      <thead>
        <tr>
          <th>Submission</th>
          <th>Client</th>
          <th>Carrier</th>
          <th>Policy</th>
          <th>Premium</th>
          <th>Sent</th>
          <th>Days</th>
          <th></th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>

    <script>
      async function loadBindQueue() {
        const res = await fetch("/api/quotes/ready-to-bind");
        if (!res.ok) return;
        const data = await res.json();
        const tbody = document.querySelector("#bind-table tbody");
        tbody.innerHTML = "";
        (data.items || []).forEach((item) => {
          const tr = document.createElement("tr");
          tr.innerHTML = `
            <td>${item.submission_public_id}</td>
            <td>${item.client_name || ""}</td>
            <td>${item.carrier_name || ""}</td>
            <td>${item.policy_type || ""}</td>
            <td>$${(item.annual_premium || 0).toFixed(2)}</td>
            <td>${item.packet_sent_at || ""}</td>
            <td>${item.days_since_sent ?? ""}</td>
            <td><a href="/operator/bind/${item.quote_id}">Bind</a></td>
          `;
          tbody.appendChild(tr);
        });
      }

      loadBindQueue();
    </script>
  </body>
</html>

