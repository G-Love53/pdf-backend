<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>CID — Bind Queue (S6)</title>
    <style>
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        margin: 0;
        padding: 0;
        background: #0f172a;
        color: #e5e7eb;
      }
      header {
        padding: 16px 24px;
        border-bottom: 1px solid #1f2937;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 12px;
      }
      header h1 {
        font-size: 18px;
        margin: 0;
      }
      header span {
        font-size: 13px;
        color: #9ca3af;
      }
      main {
        padding: 16px 24px 32px;
      }
      .toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
        flex-wrap: wrap;
        gap: 8px;
      }
      .filter-group {
        display: flex;
        gap: 8px;
        align-items: center;
      }
      select {
        background: #020617;
        color: #e5e7eb;
        border-radius: 999px;
        border: 1px solid #1f2937;
        padding: 4px 12px;
        font-size: 13px;
      }
      table {
        border-collapse: collapse;
        width: 100%;
        margin-top: 8px;
        font-size: 13px;
      }
      th,
      td {
        padding: 8px 10px;
        border-bottom: 1px solid #1f2937;
        text-align: left;
      }
      th {
        color: #9ca3af;
        font-weight: 500;
      }
      a {
        color: #38bdf8;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <header>
      <div style="flex: 1; min-width: 0">
        <h1>Bind Queue</h1>
        <span>S6 &mdash; quotes with packets sent, ready to bind</span>
        <%- include('../partials/operator-nav', { segmentQuery: typeof segmentQuery !== 'undefined' ? segmentQuery : '', segment: typeof segment !== 'undefined' ? segment : 'all' }) %>
      </div>
    </header>
    <main>
      <table id="bind-table">
        <thead>
          <tr>
            <th>Submission</th>
            <th>Client</th>
            <th>Carrier</th>
            <th>Policy</th>
            <th>Premium</th>
            <th>Sent</th>
            <th>Days</th>
            <th></th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </main>

    <script>
      function navSegmentForApi() {
        const sel = document.getElementById("operator-nav-segment");
        if (!sel || sel.value === "all") return "";
        return sel.value;
      }

      function segmentQuerySuffix() {
        const s = navSegmentForApi();
        return s ? "?segment=" + encodeURIComponent(s) : "";
      }

      async function loadBindQueue() {
        const segment = navSegmentForApi();
        const params = new URLSearchParams();
        if (segment) params.set("segment", segment);
        const res = await fetch(
          "/api/quotes/ready-to-bind?" + params.toString(),
        );
        if (!res.ok) return;
        const data = await res.json();
        const tbody = document.querySelector("#bind-table tbody");
        tbody.innerHTML = "";
        (data.items || []).forEach((item) => {
          const tr = document.createElement("tr");
          tr.innerHTML = `
            <td>${item.submission_public_id}</td>
            <td>${item.client_name || ""}</td>
            <td>${item.carrier_name || ""}</td>
            <td>${item.policy_type || ""}</td>
            <td>$${(item.annual_premium || 0).toFixed(2)}</td>
            <td>${item.packet_sent_at || ""}</td>
            <td>${item.days_since_sent ?? ""}</td>
            <td><a href="/operator/bind/${item.quote_id}${segmentQuerySuffix()}">Bind</a></td>
          `;
          tbody.appendChild(tr);
        });
      }

      loadBindQueue();
      setInterval(loadBindQueue, 30000);
    </script>
  </body>
</html>
