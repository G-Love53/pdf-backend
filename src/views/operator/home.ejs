<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>CID — Operator Home</title>
    <style>
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        margin: 0;
        padding: 0;
        background: #020617;
        color: #e5e7eb;
      }
      header {
        padding: 16px 24px;
        border-bottom: 1px solid #1f2937;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      header h1 {
        font-size: 20px;
        margin: 0;
      }
      header span {
        font-size: 13px;
        color: #9ca3af;
      }
      header select#operator-segment {
        background: #020617;
        color: #e5e7eb;
        border-radius: 8px;
        border: 1px solid #1f2937;
        padding: 6px 10px;
        font-size: 13px;
        margin-right: 12px;
      }
      main {
        padding: 16px 24px 32px;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        margin-bottom: 24px;
      }
      a.card-metric-link {
        display: block;
        color: inherit;
        text-decoration: none;
        border-radius: 10px;
        cursor: pointer;
      }
      a.card-metric-link:focus-visible {
        outline: 2px solid #38bdf8;
        outline-offset: 2px;
      }
      a.card-metric-link:hover .card {
        border-color: #0ea5e9;
        background: #0f172a;
      }
      a.card-metric-link:hover {
        text-decoration: none;
      }
      a.card-metric-link:hover .card-metric-cta {
        color: #7dd3fc;
        text-decoration: underline;
      }
      .card {
        background: #020617;
        border-radius: 10px;
        border: 1px solid #1f2937;
        padding: 12px 14px;
        transition: border-color 0.15s ease, background 0.15s ease;
      }
      .card h2 {
        font-size: 13px;
        font-weight: 500;
        color: #9ca3af;
        margin: 0 0 6px;
      }
      .metric {
        font-size: 24px;
        font-weight: 600;
      }
      /* Same sky-blue cue as header shortcuts — whole card is the hit target */
      .card-metric-cta {
        margin-top: 10px;
        font-size: 12px;
        font-weight: 500;
        color: #38bdf8;
      }
      .section-title {
        font-size: 14px;
        font-weight: 500;
        color: #9ca3af;
        margin: 20px 0 8px;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
      }
      th,
      td {
        padding: 6px 8px;
        border-bottom: 1px solid #111827;
      }
      th {
        text-align: left;
        color: #9ca3af;
        font-weight: 500;
      }
      tbody tr:hover {
        background: #020617;
      }
      .pill {
        border-radius: 999px;
        padding: 2px 8px;
        background: #020617;
        border: 1px solid #1f2937;
        font-size: 11px;
        color: #9ca3af;
      }
      a {
        color: #38bdf8;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .btn-sm {
        appearance: none;
        border: 1px solid #334155;
        background: #0f172a;
        color: #e5e7eb;
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 12px;
        cursor: pointer;
      }
      .btn-sm:hover {
        border-color: #38bdf8;
        color: #7dd3fc;
      }
      .btn-sm:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }
      .modal-backdrop {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(2, 6, 23, 0.75);
        z-index: 50;
        align-items: center;
        justify-content: center;
        padding: 16px;
      }
      .modal-backdrop.open {
        display: flex;
      }
      .modal {
        background: #0f172a;
        border: 1px solid #334155;
        border-radius: 12px;
        padding: 16px 18px;
        width: min(480px, 100%);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.45);
      }
      .modal h3 {
        margin: 0 0 12px;
        font-size: 16px;
      }
      .modal label {
        display: block;
        font-size: 12px;
        color: #9ca3af;
        margin: 10px 0 4px;
      }
      .modal input[type="text"],
      .modal input[type="file"],
      .modal textarea {
        width: 100%;
        box-sizing: border-box;
        background: #020617;
        border: 1px solid #334155;
        border-radius: 8px;
        color: #e5e7eb;
        padding: 8px 10px;
        font-size: 13px;
      }
      .modal textarea {
        min-height: 64px;
        resize: vertical;
      }
      .modal-actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        margin-top: 14px;
      }
      .modal-status {
        font-size: 12px;
        color: #9ca3af;
        margin-top: 10px;
        min-height: 1.2em;
      }
      .subject-truncate {
        max-width: 220px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .layout {
        display: grid;
        grid-template-columns: 2fr 1.5fr;
        gap: 24px;
      }
      @media (max-width: 960px) {
        .layout {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <div>
        <h1>Operator Home</h1>
        <span id="operator-subtitle">Today at a glance — all segments (UTC day, server time)</span>
      </div>
      <div style="display: flex; align-items: center; flex-wrap: wrap; gap: 8px; font-size: 12px; color: #6b7280">
        <label for="operator-segment" style="margin: 0">Segment</label>
        <select id="operator-segment" aria-label="Filter by segment">
          <option value="all">All</option>
          <option value="bar">Bar</option>
          <option value="roofer">Roofer</option>
          <option value="plumber">Plumber</option>
          <option value="hvac">HVAC</option>
          <option value="fitness">Fitness</option>
        </select>
        <span>|</span>
        <a id="link-s4" href="/operator/extraction-review">S4 queue</a> ·
        <a id="link-s5" href="/operator/packet-builder">S5 packets</a> ·
        <a id="link-s6" href="/operator/bind">S6 binds</a>
      </div>
    </header>
    <main>
      <div
        id="bind-toast"
        style="display: none; margin-bottom: 16px; padding: 12px 14px; border-radius: 8px; font-size: 14px; border: 1px solid #1f2937;"
      ></div>
      <div class="grid" id="today-metrics">
        <a class="card-metric-link" href="/operator/today/submissions" title="Open list: submissions received today (UTC)" aria-label="Submissions today: open full list">
          <div class="card">
            <h2>Submissions (today)</h2>
            <div class="metric" id="metric-submissions-today">—</div>
            <div class="card-metric-cta">Open list →</div>
          </div>
        </a>
        <a class="card-metric-link" href="/operator/today/approved-quotes" title="Open list: quotes approved in S4 today" aria-label="Approved quotes today: open full list">
          <div class="card">
            <h2>Approved quotes (S4)</h2>
            <div class="metric" id="metric-approved-quotes-today">—</div>
            <div class="card-metric-cta">Open list →</div>
          </div>
        </a>
        <a class="card-metric-link" href="/operator/today/packets-sent" title="Open list: packets marked sent today" aria-label="Packets sent today: open full list">
          <div class="card">
            <h2>Packets sent (S5)</h2>
            <div class="metric" id="metric-packets-sent-today">—</div>
            <div class="card-metric-cta">Open list →</div>
          </div>
        </a>
        <a class="card-metric-link" href="/operator/today/binds-initiated" title="Open list: bind requests created today" aria-label="Binds initiated today: open full list">
          <div class="card">
            <h2>Binds initiated (S6)</h2>
            <div class="metric" id="metric-binds-initiated-today">—</div>
            <div class="card-metric-cta">Open list →</div>
          </div>
        </a>
        <a class="card-metric-link" href="/operator/today/policies-bound" title="Open list: policy rows created today" aria-label="Policies bound today: open full list">
          <div class="card">
            <h2>Policies bound (today)</h2>
            <div class="metric" id="metric-policies-bound-today">—</div>
            <div class="card-metric-cta">Open list →</div>
          </div>
        </a>
        <a class="card-metric-link" href="/operator/today/connect-bind-stored" title="Bind confirmation PDF rows stored today (cid-postgres / Connect documents API)" aria-label="Connect bind PDF stored today: open full list">
          <div class="card">
            <h2>Connect: bind PDF stored (today)</h2>
            <div class="metric" id="metric-connect-bind-pdf-today">—</div>
            <div class="card-metric-cta">Open list →</div>
          </div>
        </a>
        <a class="card-metric-link" href="/operator/today/connect-policy-docs-stored" title="Policy or declarations PDF rows stored today (Connect)" aria-label="Connect policy docs stored today: open full list">
          <div class="card">
            <h2>Connect: policy / dec PDFs (today)</h2>
            <div class="metric" id="metric-connect-policy-docs-today">—</div>
            <div class="card-metric-cta">Open list →</div>
          </div>
        </a>
      </div>

      <div class="layout">
        <div>
          <div class="section-title">
            Submissions waiting for carrier outreach
          </div>
          <p style="font-size: 12px; color: #6b7280; margin: 0 0 10px; line-height: 1.4">
            Only submissions with no quote row yet (nothing matched from carrier). If a quote exists, the submission is not listed here. The 6-digit suffix is one global sequence for all segments, not per inbox. Oldest-waiting first. Use <strong style="color:#d1d5db">Add quote</strong> when you have a carrier PDF but the poller did not ingest it (missing CID in email, Forward instead of compose, etc.).
          </p>
          <div class="card">
            <table>
              <thead>
                <tr>
                  <th>Submission</th>
                  <th>Client</th>
                  <th>Received</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="tbody-submissions-waiting"></tbody>
            </table>
          </div>

          <div class="section-title">Carrier quotes needing CID</div>
          <p style="font-size: 12px; color: #6b7280; margin: 0 0 10px; line-height: 1.4">
            Poller stored a carrier PDF with quote/proposal keywords but no <code style="color:#cbd5e1">CID-BAR-…</code> (or segment equivalent) in the email. Link to the correct submission to open S4.
          </p>
          <div class="card">
            <table>
              <thead>
                <tr>
                  <th>From / carrier</th>
                  <th>Subject</th>
                  <th>Received</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="tbody-quotes-needing-cid"></tbody>
            </table>
          </div>

          <div class="section-title">Quotes pending S4 review</div>
          <div class="card">
            <table>
              <thead>
                <tr>
                  <th>Submission</th>
                  <th>Client</th>
                  <th>Match</th>
                </tr>
              </thead>
              <tbody id="tbody-quotes-pending-s4"></tbody>
            </table>
          </div>
        </div>

        <div>
          <div class="section-title">Binds awaiting signature</div>
          <div class="card">
            <table>
              <thead>
                <tr>
                  <th>Submission</th>
                  <th>Carrier</th>
                  <th>Policy</th>
                </tr>
              </thead>
              <tbody id="tbody-binds-awaiting"></tbody>
            </table>
          </div>

          <div class="section-title">Upcoming policy renewals</div>
          <div class="card">
            <table>
              <thead>
                <tr>
                  <th>Renewal date</th>
                  <th>Client</th>
                  <th>Carrier</th>
                </tr>
              </thead>
              <tbody id="tbody-renewals"></tbody>
            </table>
          </div>
        </div>
      </div>

      <div id="modal-add-quote" class="modal-backdrop" aria-hidden="true">
        <div class="modal" role="dialog" aria-labelledby="modal-add-quote-title">
          <h3 id="modal-add-quote-title">Add carrier quote to S4</h3>
          <p style="font-size: 12px; color: #9ca3af; margin: 0">
            Upload the carrier PDF for <strong id="modal-add-quote-cid" style="color:#e5e7eb"></strong>. This creates a quote row and opens the S4 extraction queue.
          </p>
          <label for="modal-carrier-name">Carrier name (optional)</label>
          <input id="modal-carrier-name" type="text" placeholder="e.g. Society Insurance" />
          <label for="modal-quote-file">Carrier quote PDF</label>
          <input id="modal-quote-file" type="file" accept="application/pdf,.pdf" />
          <label for="modal-quote-note">Note (optional)</label>
          <textarea id="modal-quote-note" placeholder="Why manual upload was needed"></textarea>
          <div class="modal-status" id="modal-add-quote-status"></div>
          <div class="modal-actions">
            <button type="button" class="btn-sm" id="modal-add-quote-cancel">Cancel</button>
            <button type="button" class="btn-sm" id="modal-add-quote-submit">Upload &amp; queue S4</button>
          </div>
        </div>
      </div>

      <div id="modal-link-cid" class="modal-backdrop" aria-hidden="true">
        <div class="modal" role="dialog" aria-labelledby="modal-link-cid-title">
          <h3 id="modal-link-cid-title">Link carrier quote to submission</h3>
          <p style="font-size: 12px; color: #9ca3af; margin: 0" id="modal-link-cid-summary"></p>
          <label for="modal-link-cid-input">Submission CID</label>
          <input id="modal-link-cid-input" type="text" placeholder="CID-BAR-20260512-000036" />
          <div class="modal-status" id="modal-link-cid-status"></div>
          <div class="modal-actions">
            <button type="button" class="btn-sm" id="modal-link-cid-cancel">Cancel</button>
            <button type="button" class="btn-sm" id="modal-link-cid-submit">Link &amp; queue S4</button>
          </div>
        </div>
      </div>

      <div class="section-title" style="margin-top: 8px">
        Definitions — what “stored in Connect” means here
      </div>
      <p style="font-size: 13px; color: #9ca3af; margin: 0 0 12px; max-width: 56rem; line-height: 1.45">
        CID Connect reads the same <code style="color:#cbd5e1">documents</code> + <code style="color:#cbd5e1">policies</code> in cid-postgres as this API (see <code style="color:#cbd5e1">GET /api/connect/policies/:policyId/documents</code>).
        <strong style="color:#d1d5db">Bind confirmation</strong> = a row with <code style="color:#cbd5e1">document_role = signed_bind_docs</code> linked to the policy (typically after BoldSign completes).
        <strong style="color:#d1d5db">Policy / endorsements</strong> = uploaded carrier policy materials stored as <code style="color:#cbd5e1">policy_original</code> or <code style="color:#cbd5e1">declarations_original</code> (add more roles in the DB enum when you split endorsements).
      </p>
      <div class="layout">
        <div>
          <div class="section-title">Recent bind confirmations on file (Connect)</div>
          <div class="card">
            <table>
              <thead>
                <tr>
                  <th>Submission</th>
                  <th>Policy #</th>
                  <th>Carrier</th>
                  <th>Stored</th>
                </tr>
              </thead>
              <tbody id="tbody-connect-bind-docs"></tbody>
            </table>
          </div>
        </div>
        <div>
          <div class="section-title">Recent policy / dec pages on file (Connect)</div>
          <div class="card">
            <table>
              <thead>
                <tr>
                  <th>Submission</th>
                  <th>Policy #</th>
                  <th>Role</th>
                  <th>Stored</th>
                </tr>
              </thead>
              <tbody id="tbody-connect-policy-docs"></tbody>
            </table>
          </div>
        </div>
      </div>
    </main>

    <script>
      function fmtDate(iso) {
        if (!iso) return "";
        const d = new Date(iso);
        if (Number.isNaN(d.getTime())) return "";
        return d.toLocaleDateString();
      }

      function fmtDateTime(iso) {
        if (!iso) return "";
        const d = new Date(iso);
        if (Number.isNaN(d.getTime())) return "";
        return d.toLocaleString(undefined, {
          dateStyle: "short",
          timeStyle: "short",
        });
      }

      function currentSegmentQS() {
        const v = document.getElementById("operator-segment").value;
        if (!v || v === "all") return "";
        return "?segment=" + encodeURIComponent(v);
      }

      function syncSegmentNav() {
        const qs = currentSegmentQS();
        const v = document.getElementById("operator-segment").value;
        const sub = document.getElementById("operator-subtitle");
        if (sub) {
          const labels = {
            all: "Today at a glance — all segments (UTC day, server time)",
            bar: "Today at a glance — Bar segment only (UTC day, server time)",
            roofer: "Today at a glance — Roofer segment only (UTC day, server time)",
            plumber: "Today at a glance — Plumber segment only (UTC day, server time)",
            hvac: "Today at a glance — HVAC segment only (UTC day, server time)",
            fitness: "Today at a glance — Fitness segment only (UTC day, server time)",
          };
          sub.textContent = labels[v] || labels.all;
        }
        document.querySelectorAll("a.card-metric-link").forEach((a) => {
          try {
            const path = a.pathname || new URL(a.href, window.location.origin).pathname;
            a.href = path + qs;
          } catch (e) {
            /* ignore */
          }
        });
        const s4 = document.getElementById("link-s4");
        const s5 = document.getElementById("link-s5");
        const s6 = document.getElementById("link-s6");
        if (s4) s4.href = "/operator/extraction-review" + qs;
        if (s5) s5.href = "/operator/packet-builder" + qs;
        if (s6) s6.href = "/operator/bind" + qs;
      }

      function escapeHtml(s) {
        return String(s || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      function fileToBase64(file) {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => resolve(String(reader.result || ""));
          reader.onerror = () => reject(new Error("Failed to read file"));
          reader.readAsDataURL(file);
        });
      }

      let pendingAddQuoteCid = null;
      let pendingLinkWqiId = null;

      function openAddQuoteModal(cid) {
        pendingAddQuoteCid = cid;
        document.getElementById("modal-add-quote-cid").textContent = cid;
        document.getElementById("modal-carrier-name").value = "";
        document.getElementById("modal-quote-file").value = "";
        document.getElementById("modal-quote-note").value = "";
        document.getElementById("modal-add-quote-status").textContent = "";
        const modal = document.getElementById("modal-add-quote");
        modal.classList.add("open");
        modal.setAttribute("aria-hidden", "false");
      }

      function closeAddQuoteModal() {
        pendingAddQuoteCid = null;
        const modal = document.getElementById("modal-add-quote");
        modal.classList.remove("open");
        modal.setAttribute("aria-hidden", "true");
      }

      function openLinkCidModal(item) {
        pendingLinkWqiId = item.work_queue_item_id;
        const summary = [
          item.carrier_name || item.from_email || "Carrier",
          item.subject ? `Subject: ${item.subject}` : "",
        ]
          .filter(Boolean)
          .join(" · ");
        document.getElementById("modal-link-cid-summary").textContent = summary;
        document.getElementById("modal-link-cid-input").value = "";
        document.getElementById("modal-link-cid-status").textContent = "";
        const modal = document.getElementById("modal-link-cid");
        modal.classList.add("open");
        modal.setAttribute("aria-hidden", "false");
      }

      function closeLinkCidModal() {
        pendingLinkWqiId = null;
        const modal = document.getElementById("modal-link-cid");
        modal.classList.remove("open");
        modal.setAttribute("aria-hidden", "true");
      }

      async function submitAddQuote() {
        const statusEl = document.getElementById("modal-add-quote-status");
        const cid = pendingAddQuoteCid;
        const fileEl = document.getElementById("modal-quote-file");
        const file = fileEl && fileEl.files && fileEl.files[0];
        if (!cid || !file) {
          statusEl.textContent = "PDF file is required.";
          return;
        }
        if (!/\.pdf$/i.test(file.name || "")) {
          statusEl.textContent = "Only PDF is supported.";
          return;
        }
        statusEl.textContent = "Uploading…";
        const submitBtn = document.getElementById("modal-add-quote-submit");
        if (submitBtn) submitBtn.disabled = true;
        try {
          const fileBase64 = await fileToBase64(file);
          const res = await fetch(
            "/api/operator/submissions/" + encodeURIComponent(cid) + "/add-carrier-quote",
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                carrier_name:
                  String(document.getElementById("modal-carrier-name").value || "").trim() ||
                  null,
                filename: file.name,
                file_base64: fileBase64,
                note:
                  String(document.getElementById("modal-quote-note").value || "").trim() ||
                  null,
              }),
            },
          );
          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            statusEl.textContent = "Failed: " + (data.error || res.status);
            return;
          }
          closeAddQuoteModal();
          await loadDashboard();
          if (data.work_queue_item_id) {
            window.location.href =
              "/operator/extraction-review/" +
              encodeURIComponent(data.work_queue_item_id) +
              currentSegmentQS();
          }
        } catch (err) {
          statusEl.textContent = "Failed: " + (err.message || "error");
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      }

      async function submitLinkCid() {
        const statusEl = document.getElementById("modal-link-cid-status");
        const wqiId = pendingLinkWqiId;
        const cid = String(document.getElementById("modal-link-cid-input").value || "")
          .trim()
          .toUpperCase();
        if (!wqiId || !cid) {
          statusEl.textContent = "Submission CID is required.";
          return;
        }
        statusEl.textContent = "Linking…";
        const submitBtn = document.getElementById("modal-link-cid-submit");
        if (submitBtn) submitBtn.disabled = true;
        try {
          const res = await fetch(
            "/api/operator/quote-needs-cid/" + encodeURIComponent(wqiId) + "/link",
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ submission_public_id: cid }),
            },
          );
          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            statusEl.textContent = "Failed: " + (data.error || res.status);
            return;
          }
          closeLinkCidModal();
          await loadDashboard();
          if (data.work_queue_item_id) {
            window.location.href =
              "/operator/extraction-review/" +
              encodeURIComponent(data.work_queue_item_id) +
              currentSegmentQS();
          }
        } catch (err) {
          statusEl.textContent = "Failed: " + (err.message || "error");
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      }

      async function loadDashboard() {
        try {
          const res = await fetch(
            "/api/operator/dashboard" + currentSegmentQS(),
          );
          if (!res.ok) return;
          const data = await res.json();

          const counts = data.counts || {};
          document.getElementById("metric-submissions-today").textContent =
            counts.submissions_today ?? "0";
          document.getElementById(
            "metric-approved-quotes-today",
          ).textContent = counts.approved_quotes_today ?? "0";
          document.getElementById("metric-packets-sent-today").textContent =
            counts.packets_sent_today ?? "0";
          document.getElementById(
            "metric-binds-initiated-today",
          ).textContent = counts.binds_initiated_today ?? "0";
          document.getElementById(
            "metric-policies-bound-today",
          ).textContent = counts.policies_bound_today ?? "0";
          document.getElementById(
            "metric-connect-bind-pdf-today",
          ).textContent = counts.connect_bind_pdf_stored_today ?? "0";
          document.getElementById(
            "metric-connect-policy-docs-today",
          ).textContent = counts.connect_policy_docs_stored_today ?? "0";

          const queues = data.queues || {};

          const subTbody = document.getElementById("tbody-submissions-waiting");
          subTbody.innerHTML = "";
          (queues.submissions_waiting_outreach || []).forEach((item) => {
            const tr = document.createElement("tr");
            const cid = item.submission_public_id || "";
            tr.innerHTML = `
              <td>${escapeHtml(cid || "—")}</td>
              <td>${escapeHtml(item.client_name || "")}</td>
              <td>${fmtDate(item.created_at)}</td>
              <td>${
                cid
                  ? `<button type="button" class="btn-sm btn-add-quote" data-cid="${escapeHtml(cid)}">Add quote</button>`
                  : ""
              }</td>
            `;
            subTbody.appendChild(tr);
          });
          subTbody.querySelectorAll(".btn-add-quote").forEach((btn) => {
            btn.addEventListener("click", () => openAddQuoteModal(btn.getAttribute("data-cid")));
          });

          const needsCidTbody = document.getElementById("tbody-quotes-needing-cid");
          if (needsCidTbody) {
            needsCidTbody.innerHTML = "";
            const needsCidItems = queues.quotes_needing_cid || [];
            if (!needsCidItems.length) {
              const tr = document.createElement("tr");
              tr.innerHTML = `<td colspan="4" style="color:#6b7280">None waiting — poller will add rows when a PDF has quote keywords but no CID.</td>`;
              needsCidTbody.appendChild(tr);
            }
            needsCidItems.forEach((item) => {
              const tr = document.createElement("tr");
              const fromLabel = escapeHtml(item.carrier_name || item.from_email || "—");
              const subject = escapeHtml(item.subject || "—");
              tr.innerHTML = `
                <td>${fromLabel}</td>
                <td class="subject-truncate" title="${subject}">${subject}</td>
                <td>${fmtDate(item.created_at)}</td>
                <td><button type="button" class="btn-sm btn-link-cid" data-wqi="${escapeHtml(item.work_queue_item_id)}">Link CID</button></td>
              `;
              tr.querySelector(".btn-link-cid")._item = item;
              needsCidTbody.appendChild(tr);
            });
            needsCidTbody.querySelectorAll(".btn-link-cid").forEach((btn) => {
              btn.addEventListener("click", () => openLinkCidModal(btn._item));
            });
          }

          const s4Tbody = document.getElementById("tbody-quotes-pending-s4");
          s4Tbody.innerHTML = "";
          (queues.quotes_pending_s4 || []).forEach((item) => {
            const tr = document.createElement("tr");
            tr.innerHTML = `
              <td>${item.submission_public_id || "—"}</td>
              <td>${item.client_name || ""}</td>
              <td>
                <span class="pill">
                  ${item.match_confidence_label || "unknown"}
                </span>
              </td>
            `;
            s4Tbody.appendChild(tr);
          });

          const bindTbody = document.getElementById("tbody-binds-awaiting");
          bindTbody.innerHTML = "";
          (queues.binds_awaiting_signature || []).forEach((item) => {
            const tr = document.createElement("tr");
            tr.innerHTML = `
              <td>${item.submission_public_id || "—"}</td>
              <td>${item.carrier_name || ""}</td>
              <td>${item.policy_type || ""}</td>
            `;
            bindTbody.appendChild(tr);
          });

          const renTbody = document.getElementById("tbody-renewals");
          renTbody.innerHTML = "";
          (queues.upcoming_policy_renewals || []).forEach((item) => {
            const tr = document.createElement("tr");
            tr.innerHTML = `
              <td>${fmtDate(item.expiration_date || item.effective_date)}</td>
              <td>${item.client_name || ""}</td>
              <td>${item.carrier_name || ""}</td>
            `;
            renTbody.appendChild(tr);
          });

          const bindConn = document.getElementById("tbody-connect-bind-docs");
          if (bindConn) {
            bindConn.innerHTML = "";
            (queues.connect_bind_confirmation_stored || []).forEach(
              (item) => {
                const tr = document.createElement("tr");
                const submissionCell = item.submission_public_id || "—";
                const policyCell = item.policy_id
                  ? `<a href="/operator/policies/${encodeURIComponent(String(item.policy_id))}/documents${currentSegmentQS()}">${item.policy_number || "—"}</a>`
                  : (item.policy_number || "—");
                tr.innerHTML = `
                  <td>${submissionCell}</td>
                  <td>${policyCell}</td>
                  <td>${item.carrier_name || ""}</td>
                  <td>${fmtDateTime(item.stored_at)}</td>
                `;
                bindConn.appendChild(tr);
              },
            );
          }

          const polConn = document.getElementById("tbody-connect-policy-docs");
          if (polConn) {
            polConn.innerHTML = "";
            (queues.connect_policy_documents_stored || []).forEach((item) => {
              const tr = document.createElement("tr");
              const submissionCell = item.submission_public_id || "—";
              const policyCell = item.policy_id
                ? `<a href="/operator/policies/${encodeURIComponent(String(item.policy_id))}/documents${currentSegmentQS()}">${item.policy_number || "—"}</a>`
                : (item.policy_number || "—");
              tr.innerHTML = `
                <td>${submissionCell}</td>
                <td>${policyCell}</td>
                <td>${item.last_document_role || "—"}</td>
                <td>${fmtDateTime(item.stored_at)}</td>
              `;
              polConn.appendChild(tr);
            });
          }
        } catch (err) {
          // swallow for operator UI; console is enough
          console.error("dashboard load error", err);
        }
      }

      (function initSegmentFromUrl() {
        const p = new URLSearchParams(window.location.search);
        const raw = (p.get("segment") || "all").toLowerCase();
        const allowed = ["all", "bar", "roofer", "plumber", "hvac", "fitness"];
        const seg = allowed.includes(raw) ? raw : "all";
        const sel = document.getElementById("operator-segment");
        if (sel) sel.value = seg;
      })();
      syncSegmentNav();
      document
        .getElementById("operator-segment")
        .addEventListener("change", function () {
          const v = this.value || "all";
          const u = new URL(window.location.href);
          if (v === "all") u.searchParams.delete("segment");
          else u.searchParams.set("segment", v);
          history.replaceState({}, "", u);
          syncSegmentNav();
          loadDashboard();
        });

      loadDashboard();
      setInterval(loadDashboard, 30000);

      document
        .getElementById("modal-add-quote-cancel")
        ?.addEventListener("click", closeAddQuoteModal);
      document
        .getElementById("modal-add-quote-submit")
        ?.addEventListener("click", submitAddQuote);
      document
        .getElementById("modal-link-cid-cancel")
        ?.addEventListener("click", closeLinkCidModal);
      document
        .getElementById("modal-link-cid-submit")
        ?.addEventListener("click", submitLinkCid);
      document.getElementById("modal-add-quote")?.addEventListener("click", (e) => {
        if (e.target.id === "modal-add-quote") closeAddQuoteModal();
      });
      document.getElementById("modal-link-cid")?.addEventListener("click", (e) => {
        if (e.target.id === "modal-link-cid") closeLinkCidModal();
      });

      (function bindRedirectToast() {
        const p = new URLSearchParams(window.location.search);
        const toast = document.getElementById("bind-toast");
        if (!toast) return;
        if (p.get("bind_signed") === "1") {
          toast.style.display = "block";
          toast.style.background = "#052e16";
          toast.style.borderColor = "#166534";
          const qid = p.get("quote_id");
          toast.innerHTML = qid
            ? `Bind completed — policy created. <a href="/operator/bind/${encodeURIComponent(qid)}">View bind</a>`
            : "Bind completed — policy created.";
        } else if (p.get("bind_pending") === "1") {
          toast.style.display = "block";
          toast.style.background = "#422006";
          toast.style.borderColor = "#a16207";
          toast.textContent =
            "Signature is still processing on BoldSign’s side (or the webhook will finish shortly). Refresh this page in a minute.";
        } else if (p.get("bind_error")) {
          toast.style.display = "block";
          toast.style.background = "#450a0a";
          toast.style.borderColor = "#991b1b";
          toast.textContent =
            "Could not finalize bind from redirect. Check Render logs or BoldSign webhooks.";
        }
      })();
    </script>
  </body>
  </html>

